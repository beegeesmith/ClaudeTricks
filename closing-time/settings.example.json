{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/reset-markers.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "CLOSING_TIME_WORKSPACE=\"$HOME/code\" $HOME/.claude/hooks/mark-work.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "CLOSING_TIME_WORKSPACE=\"$HOME/code\" CLOSING_TIME_VAULT_DIR=\"$HOME/ObsidianVault/Projects\" $HOME/.claude/hooks/closing-time.sh"
          }
        ]
      }
    ]
  }
}
